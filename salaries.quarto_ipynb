   "source": [
    "#| code-fold: true\n",
    "\n",
    "\n",
    "import plotly.graph_objects as go\n",
    "fig = go.Figure()\n",
    "\n",
    "fig.add_trace(go.Scatter(x=28+np.cumsum(years_ENSTA), y=Salaire_ENSTA_Brest_prime, visible='legendonly', mode='lines+markers', name=f'ENSTA Brest', line=dict(color='blue', dash='dash', shape='hv'), marker=dict(symbol='cross')))\n",
    "\n",
    "fig.add_trace(go.Scatter(x=28+np.cumsum(years_ENSTA), y=Salaire_ENSTA_Pal_prime, mode='lines+markers', name=f'ENSTA Palaiseau', line=dict(color='blue', shape='hv'), marker=dict(symbol='circle')))\n",
    "\n",
    "\n",
    "fig.add_trace(go.Scatter(x=28+np.cumsum(years_mcf_default), y=Salaire_mcf_Pal_2025, mode='lines+markers', name='MCF pal 2025', line=dict(color='red', dash='dash', shape='hv'), marker=dict(symbol='circle')))\n",
    "\n",
    "fig.add_trace(go.Scatter(x=28+np.cumsum(years_mcf_default), y=Salaire_mcf_Brest_2025, visible='legendonly', mode='lines+markers', name='MCF Brest 2025 ', line=dict(color='red', dash='dash', shape='hv'), marker=dict(symbol='cross')))\n",
    "\n",
    "fig.add_trace(go.Scatter(x=28+np.cumsum(years_mcf_default), y=Salaire_mcf_Pal_2025_2027, mode='lines+markers', name='MCF pal 2025 2027 ', line=dict(color='darkgreen', dash='dash', shape='hv'), marker=dict(symbol='circle')))\n",
    "\n",
    "fig.add_trace(go.Scatter(x=28+np.cumsum(years_mcf_default), y=Salaire_mcf_Brest_2025_2027, visible='legendonly', mode='lines+markers', name='MCF Brest 2025 2027 ', line=dict(color='darkgreen', dash='dash', shape='hv'), marker=dict(symbol='cross')))\n",
    "\n",
    "fig.add_trace(go.Scatter(x=28+np.cumsum(years_mcf_default), y=Salaire_mcf_Pal_2026_2027, mode='lines+markers', name='MCF pal 2026 2027 ', line=dict(color='green', shape='hv'), marker=dict(symbol='circle')))\n",
    "\n",
    "fig.add_trace(go.Scatter(x=28+np.cumsum(years_mcf_default), y=Salaire_mcf_Brest_2026_2027, visible='legendonly', mode='lines+markers', name='MCF Brest 2026 2027 ', line=dict(color='green', shape='hv'), marker=dict(symbol='cross')))\n",
    "\n",
    "\n",
    "fig.add_hline(\n",
    "    y=2*SMIC, \n",
    "    line_width=2, \n",
    "    line_dash=\"dash\", \n",
    "    line_color=\"black\",\n",
    "    annotation_text=\"2x SMIC\", # Optional label\n",
    "    annotation_position=\"top right\" # Optional positioning (e.g., \"top left\", \"bottom right\")\n",
    ")\n",
    "\n",
    "############## Plotly\n",
    "fig.update_layout(title='Évolution de la rémunération', xaxis_title='Âge', yaxis_title='Rémunération mensuelle (€)', template='plotly_white', legend=dict(title='Catégorie'), font=dict(size=12), width=1000, height=600)\n",
    "fig.update_xaxes(showgrid=True, gridwidth=1, gridcolor='lightgrey')\n",
    "fig.update_yaxes(showgrid=True, gridwidth=1, gridcolor='lightgrey')\n",
    "# mo.ui.plotly(fig)\n",
    "fig.show()"
   ]
  }
 ],
